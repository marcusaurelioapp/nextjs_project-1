# LotoSmart Pro — variáveis de ambiente
# Copie para .env (ou exporte no shell) e preencha com seus valores.
# Sem essas variáveis, o servidor usa o banco SQLite local (server/lotofacil.db).

# Banco Turso (produção/Vercel) — crie em https://turso.tech
# URL do banco, formato: libsql://NOME-DO-BANCO-usuario.turso.io
TURSO_DATABASE_URL=

# Token de acesso do banco (gere no painel do Turso ou com `turso db tokens create NOME`)
TURSO_AUTH_TOKEN=

# Porta da API local (opcional, padrão 3001)
# PORT=3001

# Chave secreta para assinar tokens JWT — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OBRIGATÓRIO em produção; em desenvolvimento usa-se um valor padrão inseguro com aviso no console.
JWT_SECRET=
